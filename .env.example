# Обязательные переменные
YOOKASSA_SHOP_ID='change_me'
YOOKASSA_API_KEY='change_me'

MOY_NALOG_LOGIN='change_me'
MOY_NALOG_PASSWORD='change_me'

# Таймзона (для корректного времени в чеках)
TZ='Europe/Moscow'

# Шаблон описания дохода в Мой Налог.
# Доступные переменные: {description}, {id}, {payment_description},
# {order_number}, {invoice_id}, {customer_name}, {amount}, {merchant_customer_id}
INCOME_DESCRIPTION_TEMPLATE='Платеж #{description}'

# Путь к SQLite базе (для API). По умолчанию: app/checks.db
#DB_PATH='/opt/yookassa-to-mynalog/checks.db'

# Токен авторизации для API. Все запросы должны содержать заголовок:
#   Authorization: Bearer <API_TOKEN>
API_TOKEN='change_me'
